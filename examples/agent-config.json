{
  "name": "your-agent",
  "model": "claude-sonnet",

  "resources": [],

  "hooks": {
    "agentSpawn": [
      {
        "command": "<SKILL_PATH>/hooks/agent-spawn.sh",
        "description": "Load pending log entries into context"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "<SKILL_PATH>/hooks/user-prompt-submit.sh",
        "description": "Detect correction signals in user messages"
      }
    ],
    "postToolUse": [
      {
        "command": "<SKILL_PATH>/hooks/post-tool-use.sh",
        "description": "Detect errors from tool output and log them"
      }
    ],
    "stop": [
      {
        "command": "<SKILL_PATH>/hooks/stop.sh",
        "description": "Trigger session-end review and auto-cleanup"
      }
    ]
  }
}
